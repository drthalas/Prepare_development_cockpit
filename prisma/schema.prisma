generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  draft
  questionnaire
  spec_ready
  roadmap_ready
  exported
}

enum QuestionnaireStatus {
  draft
  in_progress
  completed
}

enum RepositoryMode {
  none
  existing
  new_repository
  undecided
}

enum RepositoryVisibility {
  public
  private
  internal
  unknown
  undecided
}

enum RepositoryOwner {
  user
  hermes
  codex_authenticated
  not_decided
}

enum AgentPushAccess {
  yes
  no
  unknown
}

enum DeploymentTarget {
  railway
  vercel
  render
  other
  undecided
}

enum DeploymentMode {
  manual_instructions
  prepare_config_files
  future_api_integration
}

enum DeploymentOwner {
  user
  hermes
  codex_authenticated
  not_decided
}

enum ProjectMode {
  new_project
  existing_project
}

enum ExecutionTarget {
  codex
  claude_code
  cursor
  human_developer
  multiple
  human_team
  hybrid
  unknown
  undecided
}

enum QuestionType {
  text
  textarea
  single_select
  multi_select
  boolean
  number
}

enum TaskStatus {
  todo
  in_progress
  blocked
  done
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum TaskCategory {
  coding
  manual_infrastructure
  documentation_recommendation
  qa_checkpoint
}

enum PromptTarget {
  codex
  claude
  cursor
  generic
}

enum QAMode {
  off
  minimal
  standard
  strict
  custom
}

enum TaskSystem {
  none
  linear_export
  linear_api_later
  github_issues_later
  pdlc_later
}

enum QACheckpointFrequency {
  after_every_task
  after_every_3_tasks
  after_each_phase
  before_release_only
  custom
  unknown
}

enum RoadmapStyle {
  quick_mvp
  production_ready
  enterprise_grade
  low_cost_prototype
}

enum ExportBundleType {
  linear_ready
  artifact_bundle
  markdown
  json
}

model Project {
  id                      String                @id @default(cuid())
  title                   String
  shortId                 String                @unique
  initialIdea             String                @db.Text
  targetUser              String?               @db.Text
  projectType             String?
  classificationJson      Json?
  classificationMode      String?
  classificationUpdatedAt DateTime?
  status                  ProjectStatus         @default(draft)
  repositoryMode          RepositoryMode?
  repositoryUrl           String?
  repositoryVisibility    RepositoryVisibility?
  repositoryOwner         RepositoryOwner?
  agentCanPush            AgentPushAccess?
  defaultBranch           String?
  deploymentTarget        DeploymentTarget?
  deploymentMode          DeploymentMode?
  deploymentOwner         DeploymentOwner?
  executionTarget         ExecutionTarget?
  qaPreference            QAMode?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  spec                  Spec?
  executionSettings     ExecutionSettings?
  questionnaireSessions QuestionnaireSession[]
  roadmaps              Roadmap[]
  qaConfig              QAConfig?
  exportBundles         ExportBundle[]

  @@index([status])
  @@index([updatedAt])
}

model ExecutionSettings {
  id                    String                @id @default(cuid())
  projectId             String                @unique
  executionTarget       ExecutionTarget       @default(codex)
  taskSystem            TaskSystem            @default(linear_export)
  qaMode                QAMode                @default(standard)
  qaCheckpointFrequency QACheckpointFrequency @default(after_each_phase)
  projectMode           ProjectMode           @default(new_project)
  roadmapStyle          RoadmapStyle          @default(production_ready)
  deploymentTarget      DeploymentTarget      @default(undecided)
  deploymentMode        DeploymentMode        @default(manual_instructions)
  deploymentOwner       DeploymentOwner       @default(not_decided)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Spec {
  id               String   @id @default(cuid())
  projectId        String   @unique
  currentVersionId String?  @unique
  markdown         String   @db.Text
  structuredJson   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentVersion SpecVersion?  @relation("CurrentSpecVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions       SpecVersion[] @relation("SpecVersions")
}

model SpecVersion {
  id             String   @id @default(cuid())
  specId         String
  version        Int
  markdown       String   @db.Text
  structuredJson Json?
  createdAt      DateTime @default(now())

  spec           Spec  @relation("SpecVersions", fields: [specId], references: [id], onDelete: Cascade)
  currentForSpec Spec? @relation("CurrentSpecVersion")

  @@unique([specId, version])
  @@index([specId])
}

model QuestionnaireSession {
  id          String              @id @default(cuid())
  projectId   String
  status      QuestionnaireStatus @default(draft)
  currentStep Int?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  questions Question[]

  @@index([projectId])
  @@index([status])
}

model Question {
  id          String       @id @default(cuid())
  sessionId   String
  key         String
  label       String
  type        QuestionType
  optionsJson Json?
  order       Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  session QuestionnaireSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@unique([sessionId, key])
  @@unique([sessionId, order])
  @@index([sessionId])
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  valueJson  Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model Roadmap {
  id        String   @id @default(cuid())
  projectId String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phases  Phase[]

  @@index([projectId])
}

model Phase {
  id          String   @id @default(cuid())
  roadmapId   String
  title       String
  description String?  @db.Text
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roadmap Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([roadmapId, order])
  @@index([roadmapId])
}

model Task {
  id                     String        @id @default(cuid())
  phaseId                String
  title                  String
  description            String        @db.Text
  category               TaskCategory  @default(coding)
  status                 TaskStatus    @default(todo)
  priority               TaskPriority?
  order                  Int
  context                String?       @db.Text
  requirementsJson       Json?
  acceptanceCriteriaJson Json?
  dependenciesJson       Json?
  implementationNotes    String?       @db.Text
  linearIssueId          String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  phase   Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  prompts Prompt[]

  @@unique([phaseId, order])
  @@index([phaseId])
  @@index([status])
  @@index([linearIssueId])
}

model Prompt {
  id        String       @id @default(cuid())
  taskId    String
  target    PromptTarget
  content   String       @db.Text
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, target])
  @@index([taskId])
}

model QAConfig {
  id                  String   @id @default(cuid())
  projectId           String   @unique
  mode                QAMode   @default(standard)
  checkpointFrequency String?
  settingsJson        Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ExportBundle {
  id          String           @id @default(cuid())
  projectId   String
  type        ExportBundleType
  contentJson Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([type])
}
